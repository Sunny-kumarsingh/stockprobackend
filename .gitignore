# ============================================================
# StockPro Backend — .gitignore (Spring Boot / Maven / Docker)
# ============================================================

# ─────────────────────────────────────────
# SECRETS — Never commit
# ─────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.jks

# ─────────────────────────────────────────
# JAVA / MAVEN
# ─────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
hs_err_pid*
.mvn/wrapper/maven-wrapper.jar

# ─────────────────────────────────────────
# LOGS & UPLOADS (runtime data)
# ─────────────────────────────────────────
*.log
logs/
uploads/

# ─────────────────────────────────────────
# IDE FILES
# ─────────────────────────────────────────
.idea/
.metadata/
*.iml
*.ipr
*.iws
.classpath
.project
.settings/
.factorypath
.vscode/

# ─────────────────────────────────────────
# DOCKER
# ─────────────────────────────────────────
docker-compose.override.yml

# ─────────────────────────────────────────
# SONARQUBE
# ─────────────────────────────────────────
.sonar/
.scannerwork/

# ─────────────────────────────────────────
# OS FILES
# ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.tmp
*.swp
*~
